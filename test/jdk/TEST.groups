    javax/imageio

jdk_accessibility = \
    javax/accessibility

jfc_demo = \
     demo/jfc

jdk_editpad = \
     jdk/editpad

jdk_desktop = \
    :jdk_desktop_part1 \
    :jdk_desktop_part2 \
    :jdk_desktop_part3

jdk_desktop_part1 = \
    :jdk_client_sanity \
    :jdk_swing \
    :jdk_2d \
    :jdk_sound \
    :jdk_imageio \
    :jdk_editpad \
    :jfc_demo \
    :jdk_accessibility \
