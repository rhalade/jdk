    :jdk_instrument_sanity \
    :jdk_jmx_sanity \
    :jdk_jdi_sanity \
    :jdk_jfr_sanity \
    :svc_tools_sanity

jdk_management_sanity =

jdk_instrument_sanity =

jdk_jmx_sanity =

jdk_jdi_sanity = \
